{
  "name": "Image Sequence Sorter",
  "short_name": "Seq Sorter",
  "description": "Sort dropped-in images into an ordered sequence and generate mv commands to rename the files accordingly.",
  "start_url": ".",
  "scope": ".",
  "display": "standalone",
  "background_color": "#dcdcdc",
  "theme_color": "#2c5f8a",
  "icons": [
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "file_handlers": [
    {
      "action": "./",
      "accept": {
        "image/png": [".png"],
        "image/jpeg": [".jpg", ".jpeg"],
        "image/gif": [".gif"],
        "image/webp": [".webp"],
        "image/bmp": [".bmp"]
      }
    }
  ]
}
